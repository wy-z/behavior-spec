{
  "$schema": "https://wy-z.github.io/behavior-spec/v1/schema.json",
  "bspecVersion": "0.1.0",
  "module": {
    "id": "trading.ma-cross",
    "name": "MA-cross strategy",
    "title": "Moving Average Cross Strategy",
    "rationale": "Produces order intent from moving-average crossovers."
  },
  "interfaces": [
    { "id": "trading.market-bars", "name": "Market bar feed", "direction": "input", "protocol": "market-bar-stream" },
    { "id": "trading.broker-orders", "name": "Broker order gateway", "direction": "output", "protocol": "broker-api" }
  ],
  "observables": [
    { "id": "session.open", "name": "Session open", "role": "state", "valueSchema": { "type": "boolean" } },
    { "id": "position.quantity", "name": "Position quantity", "role": "state", "valueSchema": { "type": "integer" } },
    { "id": "portfolio.gross_exposure", "name": "Gross exposure", "role": "state", "valueSchema": { "type": "number", "minimum": 0 } },
    { "id": "strategy.enabled", "name": "Strategy enabled", "role": "state", "valueSchema": { "type": "boolean" } },
    { "id": "risk.max_order_notional", "name": "Max order notional", "role": "parameter", "valueSchema": { "type": "number", "minimum": 0 } },
    { "id": "risk.max_gross_exposure", "name": "Max gross exposure", "role": "parameter", "valueSchema": { "type": "number", "minimum": 0 } }
  ],
  "events": [
    {
      "id": "market.bar.closed",
      "name": "Bar closed",
      "direction": "input",
      "interface": "trading.market-bars",
      "payloadSchema": {
        "type": "object",
        "additionalProperties": false,
        "required": ["symbol", "close", "fast_ma", "slow_ma", "previous_fast_ma", "previous_slow_ma"],
        "properties": {
          "symbol": { "type": "string" },
          "close": { "type": "number" },
          "fast_ma": { "type": "number" },
          "slow_ma": { "type": "number" },
          "previous_fast_ma": { "type": "number" },
          "previous_slow_ma": { "type": "number" }
        }
      }
    },
    {
      "id": "broker.order.requested",
      "name": "Order requested",
      "direction": "output",
      "interface": "trading.broker-orders",
      "payloadSchema": {
        "type": "object",
        "additionalProperties": false,
        "required": ["symbol", "side", "notional"],
        "properties": {
          "symbol": { "type": "string" },
          "side": { "type": "string", "enum": ["BUY", "SELL"] },
          "notional": { "type": "number", "exclusiveMinimum": 0 }
        }
      }
    }
  ],
  "behaviors": [
    {
      "id": "trading.ma-cross.open-long",
      "name": "Open long",
      "title": "Open long after bullish MA crossover",
      "rationale": "When the market is open and we hold no position, and the fast moving average has just crossed above the slow one at this bar's close, place a BUY order.",
      "given": { "cel": "before.session.open && before.position.quantity == 0" },
      "when": {
        "event": "market.bar.closed",
        "where": { "cel": "trigger.fast_ma > trigger.slow_ma && trigger.previous_fast_ma <= trigger.previous_slow_ma" }
      },
      "then": [
        {
          "emit": {
            "event": "broker.order.requested",
            "where": { "cel": "emitted.symbol == trigger.symbol && emitted.side == 'BUY' && emitted.notional <= params.risk.max_order_notional" }
          }
        }
      ],
      "origin": [
        { "kind": "code", "uri": "strategies/ma_cross.py" }
      ]
    },
    {
      "id": "trading.ma-cross.close-long",
      "name": "Close long",
      "title": "Close long after bearish MA crossover",
      "rationale": "When we hold a long position and the fast moving average has just crossed below the slow one at this bar's close, place a SELL order to exit.",
      "given": { "cel": "before.position.quantity > 0" },
      "when": {
        "event": "market.bar.closed",
        "where": { "cel": "trigger.fast_ma < trigger.slow_ma && trigger.previous_fast_ma >= trigger.previous_slow_ma" }
      },
      "then": [
        {
          "emit": {
            "event": "broker.order.requested",
            "where": { "cel": "emitted.symbol == trigger.symbol && emitted.side == 'SELL'" }
          }
        }
      ],
      "origin": [
        { "kind": "code", "uri": "strategies/ma_cross.py" }
      ]
    }
  ],
  "invariants": [
    {
      "id": "trading.risk.max-gross-exposure",
      "name": "Exposure within limit",
      "title": "Gross exposure stays within the configured limit",
      "rationale": "Whenever the strategy is enabled, total gross exposure must never exceed the configured maximum.",
      "while": { "cel": "current.strategy.enabled" },
      "assert": { "cel": "current.portfolio.gross_exposure <= params.risk.max_gross_exposure" },
      "origin": [
        { "kind": "code", "uri": "src/risk/exposure.py" }
      ]
    }
  ],
  "flows": [
    {
      "id": "trading.trade-cycle",
      "name": "Trade cycle",
      "title": "Trading decision cycle",
      "rationale": "The end-to-end decision sequence per bar: first consider opening a long, then consider closing it.",
      "steps": ["trading.ma-cross.open-long", "trading.ma-cross.close-long"]
    }
  ]
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://bspec.dev/0.1/schema.json",
  "title": "Behavior Spec module file (v0.1)",
  "type": "object",
  "required": ["bspecVersion", "module"],
  "properties": {
    "$schema": { "type": "string" },
    "bspecVersion": { "type": "string", "const": "0.1.0" },
    "module": { "$ref": "#/$defs/module" },
    "glossary": { "type": "object", "additionalProperties": { "type": "string", "minLength": 1 } },
    "interfaces": { "type": "array", "items": { "$ref": "#/$defs/interface" } },
    "observables": { "type": "array", "items": { "$ref": "#/$defs/observable" } },
    "events": { "type": "array", "items": { "$ref": "#/$defs/event" } },
    "behaviors": { "type": "array", "items": { "$ref": "#/$defs/behavior" } },
    "invariants": { "type": "array", "items": { "$ref": "#/$defs/invariant" } },
    "flows": { "type": "array", "items": { "$ref": "#/$defs/flow" } }
  },
  "unevaluatedProperties": false,

  "$defs": {
    "generalId": { "type": "string", "pattern": "^[a-z][a-z0-9_]*(?:[.-][a-z0-9_]+)*$" },
    "celId": { "type": "string", "pattern": "^[a-z][a-z0-9_]*(?:\\.[a-z][a-z0-9_]*)*$" },
    "jsonSchema": { "type": "object" },

    "cel": {
      "type": "object",
      "required": ["cel"],
      "properties": { "cel": { "type": "string", "minLength": 1 } },
      "unevaluatedProperties": false
    },

    "module": {
      "type": "object",
      "required": ["id", "summary"],
      "properties": {
        "id": { "$ref": "#/$defs/generalId" },
        "title": { "type": "string" },
        "summary": { "type": "string", "minLength": 1 }
      },
      "unevaluatedProperties": false
    },

    "interface": {
      "type": "object",
      "required": ["id", "direction"],
      "properties": {
        "id": { "$ref": "#/$defs/generalId" },
        "title": { "type": "string" },
        "direction": { "type": "string", "enum": ["input", "output", "bidirectional"] },
        "protocol": { "type": "string" }
      },
      "unevaluatedProperties": false
    },

    "observable": {
      "type": "object",
      "required": ["id", "role", "valueSchema"],
      "properties": {
        "id": { "$ref": "#/$defs/celId" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "role": { "type": "string", "enum": ["state", "parameter", "derived"] },
        "valueSchema": { "$ref": "#/$defs/jsonSchema" }
      },
      "unevaluatedProperties": false
    },

    "event": {
      "type": "object",
      "required": ["id", "direction", "interface", "payloadSchema"],
      "properties": {
        "id": { "$ref": "#/$defs/generalId" },
        "title": { "type": "string" },
        "direction": { "type": "string", "enum": ["input", "output"] },
        "interface": { "$ref": "#/$defs/generalId" },
        "payloadSchema": { "$ref": "#/$defs/jsonSchema" }
      },
      "unevaluatedProperties": false
    },

    "behavior": {
      "type": "object",
      "required": ["id", "summary", "when", "then"],
      "properties": {
        "id": { "$ref": "#/$defs/generalId" },
        "title": { "type": "string" },
        "summary": { "type": "string", "minLength": 1 },
        "given": { "$ref": "#/$defs/cel" },
        "when": { "$ref": "#/$defs/when" },
        "then": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/thenEntry" } },
        "origin": { "type": "array", "items": { "$ref": "#/$defs/origin" } }
      },
      "unevaluatedProperties": false
    },

    "when": {
      "type": "object",
      "required": ["event"],
      "properties": {
        "event": { "$ref": "#/$defs/generalId" },
        "where": { "$ref": "#/$defs/cel" }
      },
      "unevaluatedProperties": false
    },

    "thenEntry": {
      "type": "object",
      "oneOf": [
        {
          "required": ["assert"],
          "properties": { "assert": { "$ref": "#/$defs/cel" } },
          "unevaluatedProperties": false
        },
        {
          "required": ["emit"],
          "properties": {
            "emit": {
              "type": "object",
              "required": ["event"],
              "properties": {
                "event": { "$ref": "#/$defs/generalId" },
                "where": { "$ref": "#/$defs/cel" }
              },
              "unevaluatedProperties": false
            }
          },
          "unevaluatedProperties": false
        },
        {
          "required": ["forbid"],
          "properties": {
            "forbid": {
              "type": "object",
              "required": ["event"],
              "properties": { "event": { "$ref": "#/$defs/generalId" } },
              "unevaluatedProperties": false
            }
          },
          "unevaluatedProperties": false
        }
      ]
    },

    "invariant": {
      "type": "object",
      "required": ["id", "summary", "assert"],
      "properties": {
        "id": { "$ref": "#/$defs/generalId" },
        "title": { "type": "string" },
        "summary": { "type": "string", "minLength": 1 },
        "while": { "$ref": "#/$defs/cel" },
        "assert": { "$ref": "#/$defs/cel" },
        "origin": { "type": "array", "items": { "$ref": "#/$defs/origin" } }
      },
      "unevaluatedProperties": false
    },

    "flow": {
      "type": "object",
      "required": ["id", "summary", "steps"],
      "properties": {
        "id": { "$ref": "#/$defs/generalId" },
        "title": { "type": "string" },
        "summary": { "type": "string", "minLength": 1 },
        "steps": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/generalId" } }
      },
      "unevaluatedProperties": false
    },

    "origin": {
      "type": "object",
      "required": ["kind", "uri"],
      "properties": {
        "kind": { "type": "string", "enum": ["code", "config", "doc", "runtime", "human", "inference"] },
        "uri": { "type": "string" },
        "lineStart": { "type": "integer", "minimum": 1 },
        "lineEnd": { "type": "integer", "minimum": 1 },
        "note": { "type": "string" }
      },
      "unevaluatedProperties": false
    }
  }
}
